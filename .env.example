# ============================================================
# ApplyWizard Email Tracker — Environment Variable Template
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your real values in .env.local
#   3. Never commit .env.local to Git (it is already in .gitignore)
#   4. Never put real secrets in THIS file
# ============================================================

# -- Zoho OAuth (Phase 2) ------------------------------------
# Get Client ID and Secret from: https://api-console.zoho.in
ZOHO_CLIENT_ID=YOUR_CLIENT_ID_HERE
ZOHO_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
ZOHO_REDIRECT_URI=https://applywizard.ai/api/zoho/callback

# Zoho India data center (confirmed — do not change)
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.in
ZOHO_MAIL_BASE_URL=https://mail.zoho.in/api

# Admin mailbox (confirmed — do not change)
ZOHO_ADMIN_EMAIL=ramakrishn@applywizard.ai

# Sync target mailbox — must be the tracker mailbox, never the admin mailbox.
# syncEmails.ts will refuse to run if this is missing or has no active connection.
ZOHO_SYNC_MAILBOX=tracker@applywizard.ai

# Emails per Zoho API request (page size). Integer 1–100; default 25.
ZOHO_SYNC_PAGE_SIZE=25

# Total emails fetched per cron run across all pages. Integer 1–500; default 100.
# Increase after confirming stable operation. Reduces to 0 backlog over time.
ZOHO_SYNC_MAX_PER_RUN=100

# Recent time overlap for duplicate-safe newest-first ingest. Integer 1–240 minutes; default 30.
# Used only for the fast replay window, not full historical reconciliation.
ZOHO_SYNC_REPLAY_WINDOW_MINUTES=30

# -- AI Classification (Phase 3) ----------------------------

# Max pending emails classified per cron run. Integer 1–200; default 50.
ZOHO_CLASSIFY_MAX_PER_RUN=50

# -- AI Classification (Phase 3) ----------------------------
# Primary AI: GPT-4o-mini (OpenAI)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# Secondary AI: DeepSeek (optional — Phase 3 works without this)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE

# -- Supabase (Phase 4) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# -- Cron Security (Phase 6B) --------------------------------
# A long random secret that protects GET /api/zoho/workflow/cron.
# Generate one with: openssl rand -hex 32
# Add the same value to Vercel → Project → Settings → Environment Variables.
# Never commit the real value. Never share it.
CRON_SECRET=YOUR_CRON_SECRET_HERE

# -- Dashboard Security (Phase 7A) ---------------------------
# A long random secret that protects /dashboard access.
# Generate one with: openssl rand -hex 32
# Supply as a query parameter: /dashboard?secret=YOUR_DASHBOARD_SECRET_HERE
DASHBOARD_SECRET=YOUR_DASHBOARD_SECRET_HERE
