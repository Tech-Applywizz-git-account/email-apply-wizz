{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".worker-dist",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "scripts/worker-once.ts",
    "lib/worker-core/**/*.ts",
    "lib/zoho/syncEmails.ts",
    "lib/zoho/classifyEmails.ts",
    "lib/zoho/queueFoundation.ts",
    "lib/supabase/serviceRole.ts",
    "lib/classify/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
